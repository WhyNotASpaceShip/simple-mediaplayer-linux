#!/usr/bin/env python3
"""
SimplePlayer — serves a local folder of videos over HTTP with a built-in browser player.
Zero dependencies: Python 3 stdlib only.

Usage:
    python3 player.py [FOLDER] [PORT] [--no-ffmpeg]

Defaults:
    FOLDER = current directory
    PORT   = 8080

Options:
    --no-ffmpeg   Disable ffmpeg transcoding; serve all files directly.
                  Use this if you want raw streaming regardless of audio codec.
"""

import argparse
import os
import sys
import json
import mimetypes
import urllib.parse
import socket
import shutil
import subprocess
from http.server import HTTPServer, BaseHTTPRequestHandler

# ─── config ────────────────────────────────────────────────────────────────────

def _parse_args():
    p = argparse.ArgumentParser(
        description="SimplePlayer — serve a local video folder in the browser."
    )
    p.add_argument("folder", nargs="?", default=".",
                   help="Folder to serve (default: current directory)")
    p.add_argument("port",   nargs="?", type=int, default=8080,
                   help="HTTP port (default: 8080)")
    p.add_argument("--no-ffmpeg", action="store_true",
                   help="Disable ffmpeg transcoding; stream all files directly")
    return p.parse_args()

_ARGS        = _parse_args()
VIDEO_FOLDER = os.path.abspath(_ARGS.folder)
PORT         = _ARGS.port

VIDEO_EXTS   = {".mp4", ".mkv", ".avi", ".mov", ".webm", ".m4v", ".flv",
                ".ts", ".ogv", ".ogg", ".wmv", ".mpg", ".mpeg"}

# Formats that commonly carry audio codecs browsers can't decode (AC3, DTS, EAC3, …).
# When ffmpeg is available these are transcoded on-the-fly: audio→AAC, video copied.
TRANSCODE_EXTS = {".mkv", ".avi", ".wmv", ".flv", ".mpg", ".mpeg", ".ts", ".mov"}

FFMPEG = None if _ARGS.no_ffmpeg else shutil.which("ffmpeg")

# ─── embedded UI ───────────────────────────────────────────────────────────────

HTML = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>SimplePlayer</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:      #111;
    --panel:   #1a1a1a;
    --border:  #2c2c2c;
    --accent:  #e50914;
    --text:    #ddd;
    --muted:   #666;
    --hover:   #252525;
    --active:  #1f1f1f;
  }
  html, body { height: 100%; background: var(--bg); color: var(--text);
                font-family: system-ui, sans-serif; font-size: 14px; }

  #app { display: flex; height: 100vh; }

  /* ── sidebar ── */
  #sidebar {
    width: 300px; min-width: 220px; max-width: 400px;
    display: flex; flex-direction: column;
    background: var(--panel); border-right: 1px solid var(--border);
    resize: horizontal; overflow: hidden;
  }
  #sidebar-header {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    font-weight: 700; font-size: 15px; letter-spacing: .4px;
