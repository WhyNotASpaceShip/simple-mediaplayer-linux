<body>
<div id="app">

  <div id="sidebar">
    <div id="sidebar-header">&#127916; SimplePlayer</div>
    <input id="search" type="search" placeholder="Filter videos…" autocomplete="off"/>
    <div id="count"></div>
    <div id="list"></div>
  </div>

  <div id="player-area">
    <div id="player-header">Select a video to play</div>
    <div id="video-wrap">
      <div id="placeholder">
